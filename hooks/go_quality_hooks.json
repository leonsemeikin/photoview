{
  "hooks": {
    "PostToolUse": [
      {
        "name": "Photoview Go Quality & Test",
        "matcher": "Write:*.go|Edit:*.go",
        "hooks": [
          {
            "type": "command",
            "command": "gofmt -w .",
            "description": "Format Go code"
          },
          {
            "type": "command",
            "command": "go vet ./... || exit 2",
            "description": "Run go vet"
          },
          {
            "type": "command",
            "command": "golangci-lint run || exit 2",
            "description": "Run golangci-lint"
          },
          {
            "type": "command",
            "command": "go test ./... -short -count=1 -race || exit 2",
            "description": "Run tests (Photoview optimized for performance)"
          },
          {
            "type": "command",
            "command": "go test -bench=. ./... -run=^$ || exit 2",
            "description": "Run benchmarks automatically"
          }
        ]
      }
    ]
  }
}
