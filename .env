##----------Host variables-----------##
HOST_PHOTOVIEW_LOCATION=/opt/photoview
HOST_PHOTOVIEW_MEDIA_ROOT=/home/syncthing/sync

##-------Photoview variables---------##
PHOTOVIEW_DATABASE_DRIVER=sqlite
PHOTOVIEW_SQLITE_PATH=/home/photoview/database/photoview.db

## Для работы через nginx с SSL
PHOTOVIEW_UI_ENDPOINTS=https://funspace.duckdns.org/

## Периодическое сканирование (раз в сутки)
PHOTOVIEW_SCAN_PERIODIC=24h

## Опционально: Mapbox токен для карт
# MAPBOX_TOKEN=yourToken